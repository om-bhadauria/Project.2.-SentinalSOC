# Server config
PORT=4000
NODE_ENV=development

# Authentication
# Must be at least 32 characters in production. Do not commit secrets.
JWT_SECRET=super-secret-default-key-change-in-prod-12345

# Demo Admin (For React Dashboard)
# In production, this should map to a secured DB role.
DEMO_ADMIN_USER=admin
DEMO_ADMIN_EMAIL=admin@sentinel.soc
DEMO_ADMIN_PASS=SentinelDemo123!

# API Keys
# Leave blank or "demo_api_key" to engage deterministic local Stub mode in run_demo.sh
VT_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379
USE_REDIS=true

# Postgres
DATABASE_URL=postgresql://socadmin:socpassword@localhost:5432/sentinelsoc
INIT_DB=true

# Security
# Strict comma-separated list of allowed Origins. No trailing slashes.
CORS_ORIGIN=http://localhost:5173
